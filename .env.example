# capstone.api / capstone.workflow / capstone.agents / capstone.llm
LOG_LEVEL=INFO

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Per-call wall-clock limit for Gemini (seconds); avoids infinite hang in the browser
GEMINI_REQUEST_TIMEOUT_SEC=120
# Rough USD estimate from token counts (Gemini Flash–style defaults; override for your model)
GEMINI_PRICE_INPUT_PER_1M_USD=0.10
GEMINI_PRICE_OUTPUT_PER_1M_USD=0.40
# If the API only returns total tokens, set this instead of input/output (optional)
# GEMINI_PRICE_PER_1M_USD=0.25
REDIS_URL=redis://localhost:6379
# CORS: default CORS_ALLOW_ALL=1 allows any origin (no cookies). For production set
# CORS_ALLOW_ALL=0 and list origins in CORS_ORIGINS.
CORS_ALLOW_ALL=1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://[::1]:3000
# Preflight cache (seconds). Browsers may skip OPTIONS until this expires; use 0 while debugging.
CORS_PREFLIGHT_MAX_AGE=600

# Web search (tool used by researcher). Default uses deterministic mock.
WEB_SEARCH_PROVIDER=mock
WEB_SEARCH_MAX_RESULTS=3
WEB_SEARCH_TIMEOUT_SEC=8
WEB_SEARCH_RETRIES=2
# Tavily-specific (used only when WEB_SEARCH_PROVIDER=tavily)
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic

